    "The text was captured, but the AI draft couldn’t be generated right now. Review it and generate again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Text wurde erfasst, aber der KI-Entwurf konnte gerade nicht erstellt werden. Prüfe ihn und erstelle ihn erneut."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El texto se capturó, pero no se pudo generar el borrador con IA ahora mismo. Revísalo y genera de nuevo."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le texte a été capturé, mais le brouillon IA n’a pas pu être généré maintenant. Relisez-le et générez à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टेक्स्ट कैप्चर हुआ, लेकिन AI ड्राफ़्ट अभी नहीं बन सका। इसे देखें और फिर से बनाएँ।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il testo è stato catturato, ma la bozza IA non è stata generata ora. Rivedilo e genera di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストは取り込まれましたが、現在 AI 下書きを生成できません。確認してからもう一度生成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텍스트는 캡처되었지만 지금 AI 초안을 생성하지 못했습니다. 검토한 뒤 다시 생성하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De tekst is vastgelegd, maar het AI-concept kon nu niet worden gegenereerd. Bekijk deze en genereer opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O texto foi capturado, mas o rascunho por IA não pôde ser gerado agora. Revise e gere novamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文本已捕捉，但现在无法生成 AI 草稿。请检查后重新生成。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekst został przechwycony, ale szkicu AI nie można teraz wygenerować. Przejrzyj go i wygeneruj ponownie."
          }
        }
      }
    },
    "The voice transcript was captured, but the AI draft couldn’t be generated right now. Review it and generate again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Sprachtranskript wurde erfasst, aber der KI-Entwurf konnte gerade nicht erstellt werden. Prüfe es und erstelle ihn erneut."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcripción de voz se capturó, pero no se pudo generar el borrador con IA ahora mismo. Revísala y genera de nuevo."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "La transcription vocale a été capturée, mais le brouillon IA n’a pas pu être généré maintenant. Relisez-la et générez à nouveau."
          }
        },
        "hi": {
          "stringUnit": {
