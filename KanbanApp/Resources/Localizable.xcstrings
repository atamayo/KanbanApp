          }
        }
      }
    },
    "Priority signals, WIP guidance, and visible task states help the user choose what to finish next with less friction.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Las señales de prioridad, la guía WIP y los estados visibles ayudan a elegir qué terminar después con menos fricción."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prioritätssignale, WIP-Hinweise und sichtbare Aufgabenstatus helfen dabei, mit weniger Reibung zu wählen, was als Nächstes erledigt werden soll."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "优先级信号、WIP 指引和可见任务状态，可以帮助用户更轻松地选择下一步要完成什么。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "優先度のサイン、WIP ガイダンス、見えるタスク状態によって、次に何を完了すべきかを迷いにくくします。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्राथमिकता संकेत, WIP मार्गदर्शन और दिखती हुई कार्य स्थितियाँ उपयोगकर्ता को कम रुकावट के साथ अगला पूरा करने योग्य काम चुनने में मदद करती हैं।"
          }
        }
      }
    },
    "Protect your attention": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Protege tu atención"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schütze deine Aufmerksamkeit"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保护你的注意力"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "注意力を守る"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना ध्यान बचाएँ"
          }
        }
      }
    },
    "Protect your focus": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Protege tu foco"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schütze deinen Fokus"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保护你的专注"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "集中を守る"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपना फोकस बचाएँ"
          }
        }
      }
    },
    "Pull instead of overload": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Traer trabajo en vez de sobrecargarte"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Holen statt überladen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拉入工作，而不是过载"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "抱え込まずに引き込む"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओवरलोड के बजाय काम खींचें"
          }
        }
      }
    },
    "Pull only if the next task is small or urgent. Otherwise, finish active work first.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae trabajo solo si la siguiente tarea es pequeña o urgente. Si no, termina primero el trabajo activo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol nur dann Arbeit herein, wenn die nächste Aufgabe klein oder dringend ist. Sonst erledige zuerst aktive Arbeit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当下一个任务很小或很紧急时才拉入。否则，先完成活跃工作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のタスクが小さい、または緊急の場合だけ引き込みましょう。それ以外は、まずアクティブな作業を完了します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगला कार्य छोटा या ज़रूरी हो तभी खींचें। नहीं तो पहले सक्रिय काम पूरा करें।"
          }
        }
      }
    },
    "Pull only when there is room": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae trabajo solo cuando haya hueco"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur holen, wenn Platz ist"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有空间时才拉入"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "余裕があるときだけ引き込む"
          }
        },
        "hi": {
          "stringUnit": {
