    "Resolve blocked work before pulling more tasks, unless a new task is urgent and small." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resol la feina bloquejada abans d'agafar més tasques, tret que una tasca nova sigui urgent i petita."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löse blockierte Arbeit, bevor du mehr Aufgaben hereinholst, außer eine neue Aufgabe ist dringend und klein."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resuelve el trabajo bloqueado antes de traer más tareas, salvo que una tarea nueva sea urgente y pequeña."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Résolvez le travail bloqué avant de prendre plus de tâches, sauf si une nouvelle tâche est urgente et petite."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "और कार्य खींचने से पहले रुका हुआ काम हल करें, जब तक नया कार्य छोटा और ज़रूरी न हो।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Risolvi il lavoro bloccato prima di prendere altre attività, a meno che una nuova attività sia urgente e piccola."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいタスクが緊急で小さい場合を除き、追加で引き込む前にブロック中の作業を解消しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 작업이 긴급하고 작지 않다면, 더 가져오기 전에 막힌 작업을 해결하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los geblokkeerd werk op voordat je meer taken oppakt, tenzij een nieuwe taak urgent en klein is."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rozwiąż zablokowaną pracę, zanim weźmiesz więcej zadań, chyba że nowe zadanie jest pilne i małe."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resolva trabalho bloqueado antes de puxar mais tarefas, a menos que uma nova tarefa seja urgente e pequena."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拉入更多任务前，先解决被阻塞的工作，除非新任务紧急且很小。"
          }
        }
      }
    },
