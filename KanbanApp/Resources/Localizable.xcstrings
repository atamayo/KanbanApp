    "Pull instead of overload": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Traer trabajo en vez de sobrecargarte"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Holen statt überladen"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拉入工作，而不是过载"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "抱え込まずに引き込む"
          }
        }
      }
    },
    "Pull only if the next task is small or urgent. Otherwise, finish active work first.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae trabajo solo si la siguiente tarea es pequeña o urgente. Si no, termina primero el trabajo activo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol nur dann Arbeit herein, wenn die nächste Aufgabe klein oder dringend ist. Sonst erledige zuerst aktive Arbeit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当下一个任务很小或很紧急时才拉入。否则，先完成活跃工作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のタスクが小さい、または緊急の場合だけ引き込みましょう。それ以外は、まずアクティブな作業を完了します。"
          }
        }
      }
    },
    "Pull only when there is room": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae trabajo solo cuando haya hueco"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur holen, wenn Platz ist"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有空间时才拉入"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "余裕があるときだけ引き込む"
          }
        }
      }
    },
    "Pull only when you have room": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
