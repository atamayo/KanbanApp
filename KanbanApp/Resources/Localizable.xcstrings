    "Archived Done tasks leave the active board but still count toward completion history.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tareas terminadas archivadas salen del tablero activo, pero siguen contando en el historial de finalización."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivierte erledigte Aufgaben verlassen das aktive Board, zählen aber weiterhin zur Abschluss-Historie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "归档的已完成任务会离开活跃看板，但仍会计入完成历史。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーカイブした完了タスクはアクティブなボードから外れますが、完了履歴には残ります。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आर्काइव किए गए पूरे कार्य सक्रिय बोर्ड से हट जाते हैं, लेकिन पूरा होने के इतिहास में गिने जाते हैं।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarefas concluídas arquivadas saem do quadro ativo, mas ainda contam no histórico de conclusão."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보관된 완료 작업은 활성 보드에서는 사라지지만 완료 기록에는 계속 포함됩니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tâches terminées archivées quittent le tableau actif, mais comptent toujours dans l’historique d’achèvement."
          }
        }
      }
    },
