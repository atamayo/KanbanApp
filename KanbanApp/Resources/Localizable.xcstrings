        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声入力は現在利用できません。少し待ってからもう一度お試しください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice dictation अभी उपलब्ध नहीं है। थोड़ी देर में फिर कोशिश करें।"
          }
        }
      }
    },
