        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपकी सक्रिय लेन भरी है। करना है से शुरू करने से पहले प्रगति में काम देखें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
