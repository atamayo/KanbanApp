    "Your active work is within capacity. Pull carefully or finish a current task first." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La feina activa és dins la capacitat. Agafa feina amb cura o acaba primer una tasca actual."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine aktive Arbeit liegt innerhalb der Kapazität. Hole vorsichtig Arbeit herein oder erledige zuerst eine aktuelle Aufgabe."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
