    "Track work through To Do, In Progress, and Done instead of keeping mental lists.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue el trabajo mediante Por hacer, En curso y Terminado en vez de mantener listas mentales."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge Arbeit über Zu erledigen, In Arbeit und Erledigt, statt mentale Listen zu führen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用待办、进行中和已完成来跟踪工作，而不是把清单放在脑子里。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "頭の中のリストではなく、未着手、進行中、完了で作業を追跡しましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "mental lists रखने के बजाय काम को करना है, प्रगति में और पूरा से ट्रैक करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe o trabalho por A fazer, Em andamento e Concluído, em vez de manter listas mentais."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "머릿속 목록 대신 할 일, 진행 중, 완료로 작업을 추적하세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez le travail avec À faire, En cours et Terminé au lieu de garder des listes mentales."
          }
        }
