    },
    "You're at peak capacity! Finishing '%@' will free up space.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Estás a máxima capacidad! Terminar '%@' liberará espacio."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist bei voller Kapazität! Wenn du '%@' erledigst, wird Platz frei."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经满负荷了！完成“%@”会释放空间。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "容量が上限です。「%@」を完了すると空きができます。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप पूरी क्षमता पर हैं! '%@' पूरा करने से जगह खाली होगी।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você está no pico da capacidade! Finalizar '%@' vai liberar espaço."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최대 용량입니다! “%@”을(를) 끝내면 공간이 생깁니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes à capacité maximale ! Terminer “%@” libérera de la place."
          }
        }
      }
    },
    "You're close to your WIP limit.": {
