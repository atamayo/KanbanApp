    "Apple Intelligence is unavailable, so paste text here and add it to the task manually.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ist nicht verfügbar. Füge den Text hier ein und ergänze ihn manuell zur Aufgabe."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence no está disponible, así que pega el texto aquí y añádelo a la tarea manualmente."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence est indisponible. Collez donc du texte ici et ajoutez-le manuellement à la tâche."
