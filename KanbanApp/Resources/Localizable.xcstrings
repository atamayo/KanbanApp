    "Your active lane is full. Review In Progress work before starting from To Do.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu carril activo está lleno. Revisa el trabajo En curso antes de empezar algo de Por hacer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine aktive Spalte ist voll. Prüfe Arbeit in In Arbeit, bevor du etwas aus Zu erledigen startest."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的活跃列已满。从待办开始新任务前，先检查进行中的工作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブな列がいっぱいです。未着手から始める前に、進行中の作業を確認しましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी सक्रिय लेन भरी है। करना है से शुरू करने से पहले प्रगति में काम देखें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua raia ativa está cheia. Revise o trabalho Em andamento antes de começar algo de A fazer."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 열이 가득 찼습니다. 할 일에서 새로 시작하기 전에 진행 중 작업을 검토하세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre voie active est pleine. Examinez le travail En cours avant de commencer depuis À faire."
          }
        }
      }
    },
    "Your active work is within capacity. Pull carefully or finish a current task first.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu trabajo activo está dentro de la capacidad. Trae trabajo con cuidado o termina primero una tarea actual."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine aktive Arbeit liegt innerhalb der Kapazität. Hole vorsichtig Arbeit herein oder erledige zuerst eine aktuelle Aufgabe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的活跃工作仍在容量内。谨慎拉入新工作，或先完成一个当前任务。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブな作業は容量内です。慎重に引き込むか、まず現在のタスクを完了しましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका सक्रिय काम क्षमता के भीतर है। सावधानी से खींचें या पहले मौजूदा कार्य पूरा करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu trabalho ativo está dentro da capacidade. Puxe com cuidado ou finalize uma tarefa atual primeiro."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성 작업이 용량 안에 있습니다. 신중하게 가져오거나 현재 작업을 먼저 끝내세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre travail actif est dans la capacité. Prenez prudemment ou terminez d’abord une tâche actuelle."
          }
        }
      }
    },
