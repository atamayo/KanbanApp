          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テキストを取り込みました。抽出したテキストを確認するか、下書きを生成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텍스트가 캡처되었습니다. 추출한 텍스트를 검토하거나 초안을 생성하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekst vastgelegd. Bekijk de geëxtraheerde tekst of genereer een concept."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Texto capturado. Revise o texto extraído ou gere um rascunho."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文本已捕捉。请检查提取的文本，或生成草稿。"
