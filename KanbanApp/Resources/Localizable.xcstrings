    "Your active lane is full. KanbanApp keeps the next task visible, but protects your focus first." : {
      "comment" : "A description of the warning that appears when the user has reached their limit of open tasks.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La columna activa és plena. KanbanApp manté visible la següent tasca, però protegeix primer el teu focus."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoja aktywna kolumna jest pełna. KanbanApp pokazuje następne zadanie, ale najpierw chroni Twoje skupienie."
          }
        }
      }
    },
    "Your active lane is full. Review In Progress work before starting from To Do." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
