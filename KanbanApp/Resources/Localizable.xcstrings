    "3 / 3": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "3 / 3"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "3 / 3"
          }
        }
      }
