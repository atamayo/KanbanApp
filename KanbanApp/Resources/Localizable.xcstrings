            "state": "translated",
            "value": "आपके फ़्लो में अभी जगह है।"
          }
        }
      }
    },
    "YOUR PROGRESS": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "TU PROGRESO"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DEIN FORTSCHRITT"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的进度"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रगति"
          }
        }
      }
    },
    "Your progress. %@. %lld percent complete. %@ %lld to do, %lld in progress, %lld done.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso. %@. %lld por ciento completado. %@ %lld por hacer, %lld en curso, %lld terminadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt. %@. %lld Prozent erledigt. %@ %lld zu erledigen, %lld in Arbeit, %lld erledigt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的进度。%@。已完成 %lld%%。%@ %lld 个待办，%lld 个进行中，%lld 个已完成。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗。%@。%lld%% 完了。%@ 未着手 %lld 件、進行中 %lld 件、完了 %lld 件。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रगति। %@। %lld प्रतिशत पूरा। %@ %lld करना है, %lld प्रगति में, %lld पूरे।"
          }
        }
      }
    },
    "Your progress. No tasks yet. Add your first task to start tracking progress.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso. Aún no hay tareas. Añade tu primera tarea para empezar a seguir el progreso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt. Noch keine Aufgaben. Füge deine erste Aufgabe hinzu, um Fortschritt zu verfolgen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的进度。还没有任务。添加第一个任务，开始跟踪进度。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗。まだタスクはありません。最初のタスクを追加して、進捗の記録を始めましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रगति। अभी कोई कार्य नहीं। प्रगति ट्रैक करना शुरू करने के लिए पहला कार्य जोड़ें।"
          }
        }
      }
    },
    "Your work is visible": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu trabajo es visible"
          }
