    "Dismisses the scanner without using captured text.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra el escáner sin usar el texto capturado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schließt den Scanner, ohne den erfassten Text zu verwenden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭扫描器，不使用捕捉到的文本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取り込んだテキストを使わずにスキャナーを閉じます。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैप्चर किए गए टेक्स्ट का उपयोग किए बिना स्कैनर बंद करता है।"
          }
