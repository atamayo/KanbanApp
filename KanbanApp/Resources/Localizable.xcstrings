        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ユーザーが得られるもの"
          }
        }
      }
    },
    "When your active lane is full, the dashboard pushes you back toward finishing. The app encourages pull, not overload.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando tu carril activo está lleno, el panel te empuja a volver a terminar. La app fomenta traer trabajo, no sobrecargarte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deine aktive Spalte voll ist, schiebt dich das Dashboard zurück Richtung Abschluss. Die App fördert Pull statt Überlastung."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当活跃列满了，仪表盘会把你推回完成工作。App 鼓励拉动，而不是过载。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブな列がいっぱいになると、ダッシュボードが完了へ戻るよう促します。この App は過負荷ではなく、プル型の作業を促します。"
          }
        }
      }
    },
    "When your lane is full, the app pushes you back toward finishing before pulling more work.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando tu carril está lleno, la app te empuja a terminar antes de traer más trabajo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deine Spalte voll ist, schiebt dich die App zurück Richtung Abschluss, bevor du mehr Arbeit hereinholst."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你的列满了，App 会提醒你先完成，再拉入更多工作。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "列がいっぱいのとき、この App は新しい作業を引き込む前に完了へ戻るよう促します。"
          }
        }
      }
    },
