    "Waiting work should be seen clearly, not silently mixed into active focus.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El trabajo en espera debe verse con claridad, no mezclarse en silencio con el foco activo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wartende Arbeit sollte klar sichtbar sein und nicht still in den aktiven Fokus gemischt werden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待中的工作应该清楚可见，而不是悄悄混进活跃焦点里。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "待機中の作業は、アクティブな集中対象に紛れ込ませず、はっきり見えるようにしましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंतज़ार वाला काम साफ दिखना चाहिए, सक्रिय फोकस में चुपचाप मिला हुआ नहीं।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabalho em espera deve ser visto com clareza, não misturado silenciosamente ao foco ativo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기 중인 작업은 활성 집중 속에 조용히 섞이지 않고 명확히 보여야 합니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le travail en attente doit être clairement visible, pas mélangé silencieusement à la concentration active."
          }
        }
      }
    },
    "What does done look like?": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo se ve terminado?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie sieht erledigt aus?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "什么才算完成？"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了とはどんな状態ですか？"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूरा होना कैसा दिखता है?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Como é o concluído?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "완료는 어떤 모습인가요?"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "À quoi ressemble terminé ?"
          }
        }
      }
    },
    "What needs to be done?": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué hay que hacer?"
          }
        },
        "de": {
