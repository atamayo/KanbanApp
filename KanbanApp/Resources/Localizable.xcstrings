    "Start a new task only when capacity opens. Completion creates space for the next commitment.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza una tarea nueva solo cuando se abra capacidad. Terminar crea espacio para el siguiente compromiso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starte eine neue Aufgabe nur, wenn Kapazität frei wird. Abschlüsse schaffen Platz für das nächste Commitment."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当容量释放出来时，才开始新任务。完成会为下一个承诺创造空间。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "容量が空いたときだけ新しいタスクを始めましょう。完了が次の約束のための余地を作ります。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नया कार्य तभी शुरू करें जब क्षमता खुले। पूरा होना अगले commitment के लिए जगह बनाता है।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece uma nova tarefa apenas quando houver capacidade. A conclusão cria espaço para o próximo compromisso."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여유가 생겼을 때만 새 작업을 시작하세요. 완료가 다음 약속을 위한 공간을 만듭니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez une nouvelle tâche seulement quand de la capacité se libère. L’achèvement crée de la place pour le prochain engagement."
          }
        }
      }
    },
