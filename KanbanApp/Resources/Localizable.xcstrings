    "Work in progress pressure. %@ %lld of %lld tasks active. %lld slots left. %@. %@": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Presión de trabajo en curso. %@ %lld de %lld tareas activas. Quedan %lld huecos. %@. %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Druck bei Arbeit in Arbeit. %@ %lld von %lld Aufgaben aktiv. %lld Plätze frei. %@. %@"
          }
        }
      }
    },
    "Work in progress review. %lld of %lld tasks active. %lld slots left. %lld blocked tasks. %lld ready tasks.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisión del trabajo en curso. %lld de %lld tareas activas. Quedan %lld huecos. %lld tareas bloqueadas. %lld tareas listas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfung von Arbeit in Arbeit. %lld von %lld Aufgaben aktiv. %lld Plätze frei. %lld blockierte Aufgaben. %lld bereite Aufgaben."
          }
        }
      }
    },
    "Workflow Policy": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Política de flujo de trabajo"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Workflow-Regel"
          }
        }
      }
    },
    "You are turning work into done consistently. Protect that rhythm by keeping WIP tight.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás convirtiendo trabajo en terminado de forma constante. Protege ese ritmo manteniendo el WIP ajustado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du verwandelst Arbeit konsequent in Erledigtes. Schütze diesen Rhythmus, indem du WIP eng hältst."
          }
        }
      }
    },
    "You can revisit the manifesto anytime from Settings.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes volver al manifiesto cuando quieras desde Ajustes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst das Manifest jederzeit in den Einstellungen erneut ansehen."
          }
        }
      }
    },
    "You can safely pull one more task, but keep active work tight so current tasks can reach done.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes traer una tarea más con seguridad, pero mantén ajustado el trabajo activo para que las tareas actuales puedan terminarse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst sicher noch eine Aufgabe hereinholen, aber halte aktive Arbeit eng, damit aktuelle Aufgaben erledigt werden können."
          }
        }
      }
    },
    "You're at capacity.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás al límite de capacidad."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist an der Kapazitätsgrenze."
          }
        }
      }
    },
    "You're at peak capacity! Finishing '%@' will free up space.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Estás a máxima capacidad! Terminar '%@' liberará espacio."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist bei voller Kapazität! Wenn du '%@' erledigst, wird Platz frei."
          }
        }
      }
    },
    "You're close to your WIP limit.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás cerca de tu límite WIP."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist nah an deinem WIP-Limit."
          }
        }
      }
    },
    "Your active lane is full. Review In Progress work before starting from To Do.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu carril activo está lleno. Revisa el trabajo En curso antes de empezar algo de Por hacer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine aktive Spalte ist voll. Prüfe Arbeit in In Arbeit, bevor du etwas aus Zu erledigen startest."
          }
        }
      }
    },
    "Your active work is within capacity. Pull carefully or finish a current task first.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu trabajo activo está dentro de la capacidad. Trae trabajo con cuidado o termina primero una tarea actual."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine aktive Arbeit liegt innerhalb der Kapazität. Hole vorsichtig Arbeit herein oder erledige zuerst eine aktuelle Aufgabe."
          }
        }
      }
    },
    "Your board is clear": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu tablero está despejado"
