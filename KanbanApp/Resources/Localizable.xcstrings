    "Speech recognition access is required to dictate tasks. Enable it in Settings." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cal accés al reconeixement de veu per dictar tasques. Activa-ho a Configuració."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
