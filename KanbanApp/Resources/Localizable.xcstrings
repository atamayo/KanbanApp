    "Dismisses the scanner without using captured text.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cierra el escáner sin usar el texto capturado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schließt den Scanner, ohne den erfassten Text zu verwenden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭扫描器，不使用捕捉到的文本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取り込んだテキストを使わずにスキャナーを閉じます。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैप्चर किए गए टेक्स्ट का उपयोग किए बिना स्कैनर बंद करता है।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fecha o scanner sem usar o texto capturado."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캡처한 텍스트를 사용하지 않고 스캐너를 닫습니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferme le scanner sans utiliser le texte capturé."
          }
        }
      }
    },
