    "Notifications were not enabled. You can allow them in Settings to receive active task nudges." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notificacions no s'han activat. Pots permetre-les a Configuració per rebre recordatoris de tasques actives."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benachrichtigungen wurden nicht aktiviert. Du kannst sie in den Einstellungen erlauben, um Hinweise zu aktiven Aufgaben zu erhalten."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones no se activaron. Puedes permitirlas en Ajustes para recibir recordatorios de tareas activas."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notifications n’ont pas été activées. Vous pouvez les autoriser dans Réglages pour recevoir des rappels de tâches actives."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications चालू नहीं हुईं। सक्रिय कार्य याद दिलाने के लिए आप इन्हें सेटिंग्स में अनुमति दे सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le notifiche non sono state abilitate. Puoi consentirle in Impostazioni per ricevere promemoria sulle attività attive."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通知は有効になっていません。アクティブタスク通知を受け取るには、設定で許可してください。"
