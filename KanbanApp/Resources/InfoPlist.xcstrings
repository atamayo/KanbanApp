    "NSCameraUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use the camera for Live Text scanning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the camera to scan text and turn it into a task draft."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la cámara para escanear texto y convertirlo en un borrador de tarea."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende die Kamera, um Text zu scannen und daraus einen Aufgabenentwurf zu machen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用相机扫描文本，并将其转换为任务草稿。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラを使ってテキストをスキャンし、タスクの下書きに変換します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरे का उपयोग टेक्स्ट स्कैन करने और उसे कार्य ड्राफ़्ट में बदलने के लिए करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a câmera para escanear texto e transformá-lo em um rascunho de tarefa."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp에서 사진을 가져오거나 텍스트를 스캔해 작업 초안을 만들 수 있도록 카메라 접근 권한이 필요합니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp a besoin d’accéder à la caméra pour importer des photos ou scanner du texte afin de créer des brouillons de tâches."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp richiede l’accesso alla fotocamera per importare foto o scansionare testo e creare bozze di attività."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp heeft toegang tot de camera nodig om foto’s te importeren of tekst te scannen en taakconcepten te maken."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use the microphone for voice capture.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the microphone to dictate a task and turn it into a task draft."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el micrófono para dictar una tarea y convertirla en un borrador de tarea."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende das Mikrofon, um eine Aufgabe zu diktieren und daraus einen Aufgabenentwurf zu machen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用麦克风听写任务，并将其转换为任务草稿。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクを使ってタスクを音声入力し、タスクの下書きに変換します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफ़ोन का उपयोग कार्य बोलकर लिखने और उसे कार्य ड्राफ़्ट में बदलने के लिए करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o microfone para ditar uma tarefa e transformá-la em um rascunho de tarefa."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp에서 음성으로 작업을 캡처할 수 있도록 마이크 접근 권한이 필요합니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp a besoin d’accéder au microphone pour capturer des tâches à la voix."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp richiede l’accesso al microfono per catturare attività con la voce."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp heeft toegang tot de microfoon nodig om taken met je stem vast te leggen."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use speech recognition for voice capture.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use speech recognition to transcribe dictated tasks."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el reconocimiento de voz para transcribir tareas dictadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende die Spracherkennung, um diktierte Aufgaben zu transkribieren."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用语音识别来转写听写的任务。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声認識を使って、音声入力したタスクを文字起こしします。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बोले गए कार्यों को टेक्स्ट में बदलने के लिए speech recognition का उपयोग करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o reconhecimento de fala para transcrever tarefas ditadas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp에서 음성 캡처를 작업 텍스트로 변환할 수 있도록 음성 인식 권한이 필요합니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp a besoin de la reconnaissance vocale pour convertir vos captures vocales en texte de tâche."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp richiede il riconoscimento vocale per convertire le catture vocali in testo dell’attività."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "KanbanApp heeft spraakherkenning nodig om stemopnames om te zetten naar taaktekst."
          }
        }
      }
    }
  },
  "version": "1.0"
}
