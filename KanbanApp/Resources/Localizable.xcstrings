          }
        }
      }
    },
    "What The User Gains": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Qué gana la persona usuaria"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was du dadurch gewinnst"
          }
        },
        "zh-Hans": {
          "stringUnit": {
