        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声の文字起こしは取り込まれましたが、現在 AI 下書きを生成できません。確認してからもう一度生成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성 전사는 캡처되었지만 지금 AI 초안을 생성하지 못했습니다. 검토한 뒤 다시 생성하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het stemtranscript is vastgelegd, maar het AI-concept kon nu niet worden gegenereerd. Bekijk het en genereer opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A transcrição de voz foi capturada, mas o rascunho por IA não pôde ser gerado agora. Revise e gere novamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音转写已捕捉，但现在无法生成 AI 草稿。请检查后重新生成。"
          }
        },
        "pl": {
