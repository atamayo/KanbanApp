    "The text was captured, but the AI draft couldn’t be generated right now. Review it and generate again." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'ha capturat el text, però l'esborrany d'IA no es pot generar ara mateix. Revisa'l i torna a generar-lo."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Text wurde erfasst, aber der KI-Entwurf konnte gerade nicht erstellt werden. Prüfe ihn und erstelle ihn erneut."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El texto se capturó, pero no se pudo generar el borrador con IA ahora mismo. Revísalo y genera de nuevo."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le texte a été capturé, mais le brouillon IA n’a pas pu être généré maintenant. Relisez-le et générez à nouveau."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टेक्स्ट कैप्चर हुआ, लेकिन AI ड्राफ़्ट अभी नहीं बन सका। इसे देखें और फिर से बनाएँ।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il testo è stato catturato, ma la bozza IA non è stata generata ora. Rivedilo e genera di nuovo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "テキストは取り込まれましたが、現在 AI 下書きを生成できません。確認してからもう一度生成してください。"
