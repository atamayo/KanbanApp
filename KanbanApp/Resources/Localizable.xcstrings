        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erledigte Arbeit ist Teil des Systems. Zu sehen, wie Aufgaben abgeschlossen werden, gibt Schwung und reduziert Stress."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
