    "Completion is not hidden. The dashboard and board both make finished work visible so progress feels concrete and motivating.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "La finalización no queda oculta. El panel y el tablero hacen visible el trabajo terminado para que el progreso se sienta concreto y motivador."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abschluss bleibt nicht verborgen. Dashboard und Board machen erledigte Arbeit sichtbar, damit Fortschritt konkret und motivierend wirkt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "完成不会被隐藏。仪表盘和看板都会显示已完成工作，让进展更具体，也更有动力。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了した作業は隠れません。ダッシュボードとボードの両方で見えるため、進捗が具体的で励みになります。"
          }
        }
      }
    },
