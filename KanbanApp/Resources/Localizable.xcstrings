          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या किया जाना है?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O que precisa ser feito?"
          }
        },
        "ko": {
