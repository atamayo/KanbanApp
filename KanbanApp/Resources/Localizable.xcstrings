    },
    "Voice dictation is unavailable right now. Try again in a moment.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprachdiktat ist gerade nicht verfügbar. Versuch es gleich noch einmal."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El dictado de voz no está disponible ahora mismo. Inténtalo de nuevo en un momento."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "La dictée vocale est indisponible pour le moment. Réessayez dans un instant."
          }
