    "\"%@\" has been in progress for a while. Review it before pulling more work." : {
      "comment" : "Daily notification body naming a stalled task",
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" fa una estona que és en curs. Revisa-la abans d'agafar més feina."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" ist schon eine Weile in Arbeit. Prüfe sie, bevor du mehr Arbeit hereinziehst."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" lleva un tiempo en curso. Revísala antes de traer más trabajo."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” est en cours depuis un moment. Relisez-la avant de prendre plus de travail."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” कुछ समय से प्रगति में है। और काम लेने से पहले इसे देख लें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” è in corso da un po’. Rivedila prima di prendere altro lavoro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」はしばらく進行中です。新しい作業を引き込む前に確認しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 작업이 한동안 진행 중입니다. 새 작업을 가져오기 전에 검토해 보세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” is al een tijdje in uitvoering. Bekijk deze voordat je meer werk oppakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" jest w toku już od pewnego czasu. Przejrzyj to zadanie, zanim weźmiesz kolejne."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” está em andamento há um tempo. Revise antes de puxar mais trabalho."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 已经进行了一段时间。拉入更多工作前，先检查一下。"
          }
        }
      }
    },
    "\"%@\" is starting to age in progress. A quick review can keep the board moving." : {
      "comment" : "Daily notification body naming an aging task",
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" comença a envellir en curs. Una revisió ràpida pot mantenir el tauler en moviment."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" liegt langsam zu lange in Arbeit. Eine kurze Prüfung kann das Board in Bewegung halten."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" empieza a llevar demasiado tiempo en curso. Una revisión rápida puede mantener el tablero en marcha."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” commence à vieillir en cours. Une vérification rapide peut garder le tableau en mouvement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” प्रगति में रहते हुए लंबा खिंचने लगा है। एक छोटी समीक्षा बोर्ड को आगे बढ़ाए रख सकती है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” sta iniziando a invecchiare in corso. Una rapida revisione può mantenere il flusso del tabellone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」は進行中のまま少し時間が経っています。軽く見直すと、ボードの流れを保てます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 작업이 진행 중 상태에서 오래되고 있습니다. 짧게 검토하면 보드 흐름을 유지할 수 있어요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” begint te verouderen in uitvoering. Een snelle controle kan het bord in beweging houden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" zaczyna zalegać w toku. Szybki przegląd pomoże utrzymać ruch na tablicy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” está começando a envelhecer em andamento. Uma revisão rápida pode manter o quadro fluindo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 在进行中开始变久了。快速检查一下，可以让看板继续流动。"
          }
        }
      }
    },
    "\"%@\" may need a decision. %lld more active %@ are aging." : {
      "comment" : "Daily notification body naming a stalled task and summarizing aging tasks",
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" pot necessitar una decisió. %lld %@ actives més estan envellint."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" braucht vielleicht eine Entscheidung. %lld weitere aktive %@ werden langsam alt."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" puede necesitar una decisión. Hay %lld %@ activos más que están envejeciendo."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” nécessite peut-être une décision. %lld autres %@ actifs vieillissent."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” पर शायद निर्णय चाहिए। %lld और सक्रिय %@ भी लंबे खिंच रहे हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” potrebbe richiedere una decisione. Altri %lld %@ attivi stanno invecchiando."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」には判断が必要かもしれません。ほかにも %lld 件のアクティブな%@が長引いています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”에는 결정이 필요할 수 있습니다. %lld개의 활성 %@도 오래되고 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” heeft mogelijk een beslissing nodig. Nog %lld actieve %@ verouderen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" może wymagać decyzji. Jeszcze %lld aktywnych %@ zaczyna zalegać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” talvez precise de uma decisão. Mais %lld %@ ativos estão envelhecendo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” 可能需要一个决定。另有 %lld 个活跃%@也在变旧。"
          }
        }
      }
    },
