    "Use this when work cannot move forward yet. Blocked tasks should become visible quickly.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa esto cuando el trabajo aún no pueda avanzar. Las tareas bloqueadas deberían hacerse visibles rápido."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutze das, wenn Arbeit noch nicht vorankommen kann. Blockierte Aufgaben sollten schnell sichtbar werden."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当工作暂时无法推进时使用它。被阻塞的任务应该尽快变得可见。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作業がまだ前に進めないときに使います。ブロック中のタスクは早めに見えるようにしましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे तब इस्तेमाल करें जब काम अभी आगे नहीं बढ़ सकता। रुके हुए कार्य जल्दी दिखने चाहिए।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use isto quando o trabalho ainda não puder avançar. Tarefas bloqueadas devem ficar visíveis rapidamente."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업이 아직 앞으로 나아갈 수 없을 때 사용하세요. 막힌 작업은 빠르게 보이게 해야 합니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ceci quand le travail ne peut pas encore avancer. Les tâches bloquées doivent devenir visibles rapidement."
          }
        }
      }
    },
