    "Waiting work should be seen clearly, not silently mixed into active focus.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wartende Arbeit sollte klar sichtbar sein und nicht still in den aktiven Fokus gemischt werden."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El trabajo en espera debe verse con claridad, no mezclarse en silencio con el foco activo."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le travail en attente doit être clairement visible, pas mélangé silencieusement à la concentration active."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंतज़ार वाला काम साफ दिखना चाहिए, सक्रिय फोकस में चुपचाप मिला हुआ नहीं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il lavoro in attesa dovrebbe essere visto chiaramente, non mescolato in silenzio alla concentrazione attiva."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "待機中の作業は、アクティブな集中対象に紛れ込ませず、はっきり見えるようにしましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대기 중인 작업은 활성 집중 속에 조용히 섞이지 않고 명확히 보여야 합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wachtend werk moet duidelijk zichtbaar zijn, niet stilletjes gemengd met actieve focus."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Trabalho em espera deve ser visto com clareza, não misturado silenciosamente ao foco ativo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待中的工作应该清楚可见，而不是悄悄混进活跃焦点里。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oczekująca praca powinna być wyraźnie widoczna, a nie cicho wymieszana z aktywnym skupieniem."
          }
        }
      }
    },
    "What does done look like?": {
      "localizations": {
        "de": {
