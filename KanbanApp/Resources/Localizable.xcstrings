    "Work in progress pressure. %@ %lld of %lld tasks active. %lld slots left. %@. %@": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Presión de trabajo en curso. %@ %lld de %lld tareas activas. Quedan %lld huecos. %@. %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Druck bei Arbeit in Arbeit. %@ %lld von %lld Aufgaben aktiv. %lld Plätze frei. %@. %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "进行中工作压力。%@ %lld/%lld 个任务处于活跃状态。剩余 %lld 个位置。%@。%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中の作業圧力。%@ %lld / %lld 件がアクティブです。残り枠は %lld 件。%@。%@"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रगति में काम का दबाव। %@ %lld में से %lld कार्य सक्रिय। %lld स्लॉट बचे। %@। %@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pressão de trabalho em andamento. %@ %lld de %lld tarefas ativas. %lld espaços restantes. %@. %@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중 작업 압박. %@ 작업 %lld/%lld개 활성. 남은 슬롯 %lld개. %@. %@"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pression du travail en cours. %@ %lld sur %lld tâches actives. %lld créneaux restants. %@. %@"
          }
        }
      }
    },
    "Work in progress review. %lld of %lld tasks active. %lld slots left. %lld blocked tasks. %lld ready tasks.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisión del trabajo en curso. %lld de %lld tareas activas. Quedan %lld huecos. %lld tareas bloqueadas. %lld tareas listas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüfung von Arbeit in Arbeit. %lld von %lld Aufgaben aktiv. %lld Plätze frei. %lld blockierte Aufgaben. %lld bereite Aufgaben."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "进行中工作回顾。%lld/%lld 个任务处于活跃状态。剩余 %lld 个位置。%lld 个阻塞任务。%lld 个就绪任务。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中作業の確認。%lld / %lld 件がアクティブです。残り枠 %lld 件。ブロック中 %lld 件。準備済み %lld 件。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रगति में काम की समीक्षा। %lld में से %lld कार्य सक्रिय। %lld स्लॉट बचे। %lld रुके हुए कार्य। %lld तैयार कार्य।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisão de trabalho em andamento. %lld de %lld tarefas ativas. %lld espaços restantes. %lld tarefas bloqueadas. %lld tarefas prontas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중 작업 검토. 작업 %lld/%lld개 활성. 남은 슬롯 %lld개. 막힌 작업 %lld개. 준비된 작업 %lld개."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revue du travail en cours. %lld sur %lld tâches actives. %lld créneaux restants. %lld tâches bloquées. %lld tâches prêtes."
          }
        }
      }
    },
