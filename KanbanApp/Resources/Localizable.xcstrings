    "Quick Capture AI couldn’t generate a draft right now. Review the text and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Schnellerfassungs-KI konnte gerade keinen Entwurf erstellen. Prüfe den Text und versuch es erneut."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "La IA de Captura rápida no pudo generar un borrador ahora mismo. Revisa el texto e inténtalo de nuevo."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L’IA de Capture rapide n’a pas pu générer de brouillon maintenant. Relisez le texte et réessayez."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Capture AI अभी ड्राफ़्ट नहीं बना सका। टेक्स्ट देखें और फिर कोशिश करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’IA di Cattura rapida non è riuscita a generare una bozza ora. Rivedi il testo e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイックキャプチャ AI は現在下書きを生成できません。テキストを確認して、もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빠른 캡처 AI가 지금 초안을 생성하지 못했습니다. 텍스트를 검토하고 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Snelle vastlegging-AI kon nu geen concept genereren. Bekijk de tekst en probeer opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A IA da Captura rápida não conseguiu gerar um rascunho agora. Revise o texto e tente de novo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速捕捉 AI 现在无法生成草稿。请检查文本后重试。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "AI szybkiego przechwytywania nie może teraz wygenerować szkicu. Przejrzyj tekst i spróbuj ponownie."
          }
        }
      }
    },
