    "Speech recognition access is required to dictate tasks. Enable it in Settings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf Spracherkennung ist nötig, um Aufgaben zu diktieren. Aktiviere ihn in den Einstellungen."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso al reconocimiento de voz para dictar tareas. Actívalo en Ajustes."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès à la reconnaissance vocale est nécessaire pour dicter des tâches. Activez-le dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य बोलकर लिखने के लिए speech recognition access चाहिए। इसे सेटिंग्स में चालू करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accesso al riconoscimento vocale è necessario per dettare attività. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクを音声入力するには音声認識へのアクセスが必要です。設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업을 받아쓰려면 음성 인식 접근 권한이 필요합니다. 설정에서 허용하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegang tot spraakherkenning is vereist om taken te dicteren. Schakel dit in via Instellingen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao reconhecimento de fala é necessário para ditar tarefas. Ative em Ajustes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
