            "value": "टेक्स्ट स्कैन करने के लिए कैमरा एक्सेस चाहिए। इसे सेटिंग्स में चालू करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso à câmera é necessário para escanear texto. Ative em Ajustes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "텍스트를 스캔하려면 카메라 접근 권한이 필요합니다. 설정에서 허용하세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès à la caméra est nécessaire pour scanner du texte. Activez-le dans Réglages."
          }
        }
      }
    },
