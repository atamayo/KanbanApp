    "Live text scanning is not supported on this device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-Text-Scanning wird auf diesem Gerät nicht unterstützt."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El escaneo de texto en vivo no es compatible con este dispositivo."
          }
