          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konsekwentnie zamieniasz pracę w ukończone zadania. Chroń ten rytm, utrzymując niski WIP."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
