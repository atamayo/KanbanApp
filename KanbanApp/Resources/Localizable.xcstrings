            "state": "translated",
            "value": "作業を検索"
          }
        }
      }
    },
    "See progress, WIP pressure, and flow signals that push you toward finishing.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve el progreso, la presión WIP y las señales de flujo que te empujan a terminar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh Fortschritt, WIP-Druck und Flow-Signale, die dich Richtung Abschluss schieben."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查看进度、WIP 压力和流程信号，推动你走向完成。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗、WIP 圧力、完了へ向かうためのフローサインを確認できます。"
          }
        }
      }
    },
    "See your work clearly": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve tu trabajo con claridad"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh deine Arbeit klar"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清楚看到你的工作"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作業をはっきり見る"
          }
        }
      }
    },
    "Send one daily reminder when In Progress tasks are aging or stalled.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un recordatorio diario cuando las tareas En curso estén envejeciendo o estancadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende täglich eine Erinnerung, wenn In-Arbeit-Aufgaben altern oder feststecken."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当进行中的任务变久或停滞时，每天发送一次提醒。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中のタスクが長引いたり停滞したりしているとき、1 日 1 回リマインダーを送信します。"
          }
        }
      }
    },
    "Set a max number of active tasks so your attention stays narrow.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Define un número máximo de tareas activas para mantener la atención enfocada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege eine maximale Anzahl aktiver Aufgaben fest, damit deine Aufmerksamkeit eng fokussiert bleibt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置活跃任务上限，让注意力保持集中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなタスクの上限を設定して、注意力を絞ります。"
