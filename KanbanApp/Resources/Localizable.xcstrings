    "Priority signals, WIP guidance, and visible task states help the user choose what to finish next with less friction." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Els senyals de prioritat, la guia WIP i els estats visibles ajuden l'usuari a triar què acabar després amb menys fricció."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prioritätssignale, WIP-Hinweise und sichtbare Aufgabenstatus helfen dabei, mit weniger Reibung zu wählen, was als Nächstes erledigt werden soll."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las señales de prioridad, la guía WIP y los estados visibles ayudan a elegir qué terminar después con menos fricción."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les signaux de priorité, les conseils WIP et les états de tâche visibles aident l’utilisateur à choisir quoi finir ensuite avec moins de friction."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्राथमिकता संकेत, WIP मार्गदर्शन और दिखती हुई कार्य स्थितियाँ उपयोगकर्ता को कम रुकावट के साथ अगला पूरा करने योग्य काम चुनने में मदद करती हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segnali di priorità, guida WIP e stati delle attività visibili aiutano l’utente a scegliere cosa finire dopo con meno attrito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "優先度のサイン、WIP ガイダンス、見えるタスク状態によって、次に何を完了すべきかを迷いにくくします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "우선순위 신호, WIP 안내, 보이는 작업 상태는 사용자가 다음에 무엇을 끝낼지 더 쉽게 고르도록 돕습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prioriteitssignalen, WIP-begeleiding en zichtbare taakstatussen helpen de gebruiker met minder frictie kiezen wat hierna af moet."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sygnały priorytetu, wskazówki WIP i widoczne stany zadań pomagają wybrać, co ukończyć dalej, z mniejszym tarciem."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinais de prioridade, orientação de WIP e estados visíveis ajudam a escolher o que finalizar a seguir com menos atrito."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "优先级信号、WIP 指引和可见任务状态，可以帮助用户更轻松地选择下一步要完成什么。"
          }
        }
      }
    },
