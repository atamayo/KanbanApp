        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die nächste erledigte Aufgabe verändert das Board."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下一个完成的任务会改变看板。"
