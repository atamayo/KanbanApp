        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声入力は現在利用できません。少し待ってからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금은 음성 받아쓰기를 사용할 수 없습니다. 잠시 후 다시 시도하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraakdictatie is momenteel niet beschikbaar. Probeer het zo opnieuw."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O ditado por voz está indisponível no momento. Tente de novo em instantes."
