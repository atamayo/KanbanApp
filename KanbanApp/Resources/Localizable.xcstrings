    "Pull only if the next task is small or urgent. Otherwise, finish active work first.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hol nur dann Arbeit herein, wenn die nächste Aufgabe klein oder dringend ist. Sonst erledige zuerst aktive Arbeit."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Trae trabajo solo si la siguiente tarea es pequeña o urgente. Si no, termina primero el trabajo activo."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prenez seulement si la prochaine tâche est petite ou urgente. Sinon, terminez d’abord le travail actif."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगला कार्य छोटा या ज़रूरी हो तभी खींचें। नहीं तो पहले सक्रिय काम पूरा करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prendi solo se la prossima attività è piccola o urgente. Altrimenti, finisci prima il lavoro attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次のタスクが小さい、または緊急の場合だけ引き込みましょう。それ以外は、まずアクティブな作業を完了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 작업이 작거나 긴급할 때만 가져오세요. 그렇지 않으면 활성 작업을 먼저 끝내세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pak alleen op als de volgende taak klein of urgent is. Rond anders eerst actief werk af."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Puxe apenas se a próxima tarefa for pequena ou urgente. Caso contrário, finalize o trabalho ativo primeiro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当下一个任务很小或很紧急时才拉入。否则，先完成活跃工作。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weź kolejne zadanie tylko wtedy, gdy jest małe albo pilne. W przeciwnym razie najpierw zakończ aktywną pracę."
          }
        }
      }
    },
