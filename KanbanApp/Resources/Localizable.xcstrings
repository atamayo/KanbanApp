        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성이 캡처되었습니다. 받아쓰기에서 초안을 생성했습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stem vastgelegd. Concept gegenereerd uit je dictaat."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz capturada. Rascunho gerado a partir do seu ditado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音已捕捉。已根据你的听写生成草稿。"
