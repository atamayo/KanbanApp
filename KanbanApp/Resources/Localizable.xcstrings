            "state": "translated",
            "value": "आपका फ़्लो संतुलित है।"
          }
        }
      }
    },
    "Your flow still has room.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu flujo aún tiene margen."
          }
        },
