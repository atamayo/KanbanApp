          }
        }
      }
    },
    "The dashboard shows progress, WIP pressure, and priority distribution so you can decide whether to finish, pause, or avoid pulling more." : {
      "localizations" : {
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
