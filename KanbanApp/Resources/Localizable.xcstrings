            "state": "translated",
            "value": "Sprachdiktat ist gerade nicht verfügbar. Versuch es gleich noch einmal."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音听写现在不可用。请稍后再试。"
