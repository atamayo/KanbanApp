    "See progress, WIP pressure, and flow signals that push you toward finishing.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh Fortschritt, WIP-Druck und Flow-Signale, die dich Richtung Abschluss schieben."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve el progreso, la presión WIP y las señales de flujo que te empujan a terminar."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez la progression, la pression WIP et les signaux de flux qui vous poussent vers l’achèvement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रगति, WIP दबाव और ऐसे फ़्लो संकेत देखें जो आपको पूरा करने की ओर धकेलते हैं।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi progressi, pressione WIP e segnali di flusso che ti spingono verso il completamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
