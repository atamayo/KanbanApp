    "Microphone access is required to dictate tasks. Enable it in Settings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofonzugriff ist nötig, um Aufgaben zu diktieren. Aktiviere ihn in den Einstellungen."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso al micrófono para dictar tareas. Actívalo en Ajustes."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accès au microphone est nécessaire pour dicter des tâches. Activez-le dans Réglages."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य बोलकर लिखने के लिए माइक्रोफ़ोन एक्सेस चाहिए। इसे सेटिंग्स में चालू करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’accesso al microfono è necessario per dettare attività. Abilitalo in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクを音声入力するにはマイクへのアクセスが必要です。設定で有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업을 받아쓰려면 마이크 접근 권한이 필요합니다. 설정에서 허용하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Microfoontoegang is vereist om taken te dicteren. Schakel dit in via Instellingen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O acesso ao microfone é necessário para ditar tarefas. Ative em Ajustes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "听写任务需要麦克风权限。请在设置中开启。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostęp do mikrofonu jest wymagany do dyktowania zadań. Włącz go w Ustawieniach."
          }
        }
      }
    },
    "Momentum is building across your board.": {
      "localizations": {
        "de": {
          "stringUnit": {
