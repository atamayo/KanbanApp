    "Send one daily reminder when In Progress tasks are aging or stalled.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un recordatorio diario cuando las tareas En curso estén envejeciendo o estancadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende täglich eine Erinnerung, wenn In-Arbeit-Aufgaben altern oder feststecken."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当进行中的任务变久或停滞时，每天发送一次提醒。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中のタスクが長引いたり停滞したりしているとき、1 日 1 回リマインダーを送信します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब प्रगति में कार्य लंबे खिंचें या रुकें, तो रोज़ एक reminder भेजें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envie um lembrete diário quando tarefas Em andamento estiverem envelhecendo ou paradas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중 작업이 오래되거나 지연되면 하루에 한 번 알림을 보냅니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer un rappel quotidien quand les tâches En cours vieillissent ou sont bloquées."
          }
        }
      }
    },
    "Set a max number of active tasks so your attention stays narrow.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Define un número máximo de tareas activas para mantener la atención enfocada."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege eine maximale Anzahl aktiver Aufgaben fest, damit deine Aufmerksamkeit eng fokussiert bleibt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置活跃任务上限，让注意力保持集中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなタスクの上限を設定して、注意力を絞ります。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सक्रिय कार्यों की अधिकतम संख्या तय करें ताकि ध्यान सीमित रहे।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Defina um número máximo de tarefas ativas para manter sua atenção concentrada."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주의를 좁게 유지하도록 활성 작업의 최대 개수를 설정하세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
