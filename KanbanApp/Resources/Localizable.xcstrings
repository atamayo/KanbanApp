    "Voice captured. Apple Intelligence is unavailable, so the transcript was added for manual review.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz capturada. Apple Intelligence no está disponible, así que la transcripción se añadió para revisarla manualmente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprache erfasst. Apple Intelligence ist nicht verfügbar, deshalb wurde das Transkript zur manuellen Prüfung hinzugefügt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音已捕捉。Apple Intelligence 不可用，转写文本已添加供你手动检查。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声を取り込みました。Apple Intelligence を利用できないため、文字起こしを手動確認用に追加しました。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आवाज़ कैप्चर हुई। Apple Intelligence उपलब्ध नहीं है, इसलिए ट्रांसक्रिप्ट मैन्युअल समीक्षा के लिए जोड़ दिया गया।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz capturada. O Apple Intelligence está indisponível, então a transcrição foi adicionada para revisão manual."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성이 캡처되었습니다. Apple Intelligence를 사용할 수 없어 전사 내용을 수동 검토용으로 추가했습니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voix capturée. Apple Intelligence est indisponible, donc la transcription a été ajoutée pour une relecture manuelle."
          }
        }
      }
    },
    "Voice captured. Draft generated from your dictation.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz capturada. Borrador generado a partir de tu dictado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprache erfasst. Entwurf aus deinem Diktat erstellt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音已捕捉。已根据你的听写生成草稿。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声を取り込みました。音声入力から下書きを生成しました。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आवाज़ कैप्चर हुई। आपकी dictation से ड्राफ़्ट बन गया।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voz capturada. Rascunho gerado a partir do seu ditado."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음성이 캡처되었습니다. 받아쓰기에서 초안을 생성했습니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Voix capturée. Brouillon généré depuis votre dictée."
          }
        }
      }
    },
    "Voice captured. Review the transcript or generate a draft.": {
