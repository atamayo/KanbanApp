    "Finish one before pulling another.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Termina una antes de traer otra."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erledige eine, bevor du die nächste hereinholst."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先完成一个，再拉入下一个。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次を引き込む前に、まず 1 つ完了しましょう。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दूसरा लेने से पहले एक पूरा करें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Finalize uma antes de puxar outra."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 작업을 가져오기 전에 하나를 끝내세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminez-en une avant d’en prendre une autre."
          }
        }
      }
    },
    "Finish one task before pulling another.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
