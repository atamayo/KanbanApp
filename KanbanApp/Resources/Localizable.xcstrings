          }
        }
      }
    },
    "Your progress. No tasks yet. Add your first task to start tracking progress.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso. Aún no hay tareas. Añade tu primera tarea para empezar a seguir el progreso."
          }
        },
        "de": {
          "stringUnit": {
