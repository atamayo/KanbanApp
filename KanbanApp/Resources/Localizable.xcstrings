            "value": "Zu viel Arbeit ist aktiv."
          }
        }
      }
    },
    "Track work through To Do, In Progress, and Done instead of keeping mental lists.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue el trabajo mediante Por hacer, En curso y Terminado en vez de mantener listas mentales."
          }
