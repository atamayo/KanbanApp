    "Double-tap to open details. Swipe or long press for actions. Drag the card to reorder." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dues vegades per obrir els detalls. Fes lliscar o mantén premut per a accions. Arrossega la targeta per reordenar."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doppeltippen öffnet Details. Wische oder halte gedrückt für Aktionen. Ziehe die Karte, um sie neu zu sortieren."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dos veces para abrir los detalles. Desliza o mantén pulsado para ver acciones. Arrastra la tarjeta para reordenarla."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez deux fois pour ouvrir les détails. Balayez ou appuyez longuement pour les actions. Faites glisser la carte pour réordonner."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "विवरण खोलने के लिए दो बार टैप करें। कार्रवाइयों के लिए स्वाइप या लंबा दबाएँ। क्रम बदलने के लिए कार्ड खींचें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca due volte per aprire i dettagli. Scorri o tieni premuto per le azioni. Trascina la scheda per riordinare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダブルタップで詳細を開きます。スワイプまたは長押しで操作できます。カードをドラッグして並べ替えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "두 번 탭하면 세부 정보가 열립니다. 쓸어넘기거나 길게 눌러 작업을 실행하세요. 카드를 끌어 순서를 바꿀 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik dubbel om details te openen. Veeg of druk lang voor acties. Sleep de kaart om te herschikken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stuknij dwukrotnie, aby otworzyć szczegóły. Przesuń lub przytrzymaj, aby wykonać działania. Przeciągnij kartę, aby zmienić kolejność."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque duas vezes para abrir os detalhes. Deslize ou mantenha pressionado para ações. Arraste o cartão para reordenar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "双击打开详情。滑动或长按可执行操作。拖动卡片可重新排序。"
          }
        }
      }
    },
