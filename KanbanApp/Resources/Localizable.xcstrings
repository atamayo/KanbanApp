    "Your progress. %@. %lld percent complete. %@ %lld to do, %lld in progress, %lld done.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt. %@. %lld Prozent erledigt. %@ %lld zu erledigen, %lld in Arbeit, %lld erledigt."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso. %@. %lld por ciento completado. %@ %lld por hacer, %lld en curso, %lld terminadas."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre progression. %@. %lld pour cent terminés. %@ %lld à faire, %lld en cours, %lld terminées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रगति। %@। %lld प्रतिशत पूरा। %@ %lld करना है, %lld प्रगति में, %lld पूरे।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi progressi. %@. %lld percento completato. %@ %lld da fare, %lld in corso, %lld completate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗。%@。%lld%% 完了。%@ 未着手 %lld 件、進行中 %lld 件、完了 %lld 件。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 상황. %@. %lld퍼센트 완료. %@ 할 일 %lld개, 진행 중 %lld개, 완료 %lld개."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je voortgang. %@. %lld procent voltooid. %@ %lld te doen, %lld in uitvoering, %lld klaar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu progresso. %@. %lld por cento concluído. %@ %lld a fazer, %lld em andamento, %lld concluídas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的进度。%@。已完成 %lld%%。%@ %lld 个待办，%lld 个进行中，%lld 个已完成。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój postęp. %@. Ukończono %lld procent. %@ %lld do zrobienia, %lld w toku, %lld ukończone."
          }
        }
      }
    },
    "Your progress. No tasks yet. Add your first task to start tracking progress.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Fortschritt. Noch keine Aufgaben. Füge deine erste Aufgabe hinzu, um Fortschritt zu verfolgen."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu progreso. Aún no hay tareas. Añade tu primera tarea para empezar a seguir el progreso."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre progression. Pas encore de tâches. Ajoutez votre première tâche pour commencer à suivre la progression."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी प्रगति। अभी कोई कार्य नहीं। प्रगति ट्रैक करना शुरू करने के लिए पहला कार्य जोड़ें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi progressi. Ancora nessuna attività. Aggiungi la tua prima attività per iniziare a monitorare i progressi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進捗。まだタスクはありません。最初のタスクを追加して、進捗の記録を始めましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 상황. 아직 작업이 없습니다. 진행을 추적하려면 첫 작업을 추가하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je voortgang. Nog geen taken. Voeg je eerste taak toe om voortgang te volgen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu progresso. Ainda não há tarefas. Adicione sua primeira tarefa para começar a acompanhar o progresso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的进度。还没有任务。添加第一个任务，开始跟踪进度。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój postęp. Nie ma jeszcze zadań. Dodaj pierwsze zadanie, aby zacząć śledzić postęp."
          }
        }
      }
    },
