    "Start a new task only when capacity opens. Completion creates space for the next commitment." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comença una tasca nova només quan s'obri capacitat. Acabar crea espai per al següent compromís."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte eine neue Aufgabe nur, wenn Kapazität frei wird. Abschlüsse schaffen Platz für das nächste Commitment."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza una tarea nueva solo cuando se abra capacidad. Terminar crea espacio para el siguiente compromiso."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commencez une nouvelle tâche seulement quand de la capacité se libère. L’achèvement crée de la place pour le prochain engagement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "नया कार्य तभी शुरू करें जब क्षमता खुले। पूरा होना अगले commitment के लिए जगह बनाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inizia una nuova attività solo quando si libera capacità. Il completamento crea spazio per il prossimo impegno."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "容量が空いたときだけ新しいタスクを始めましょう。完了が次の約束のための余地を作ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여유가 생겼을 때만 새 작업을 시작하세요. 완료가 다음 약속을 위한 공간을 만듭니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start alleen een nieuwe taak wanneer er capaciteit vrijkomt. Voltooiing maakt ruimte voor de volgende commitment."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaczynaj nowe zadanie tylko wtedy, gdy pojawi się pojemność. Ukończenie tworzy miejsce na kolejne zobowiązanie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comece uma nova tarefa apenas quando houver capacidade. A conclusão cria espaço para o próximo compromisso."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只有当容量释放出来时，才开始新任务。完成会为下一个承诺创造空间。"
          }
        }
      }
    },
