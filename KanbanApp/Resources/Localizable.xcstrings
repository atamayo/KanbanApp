    "Use the board to choose deliberately, the dashboard to protect flow, and the Done column to keep momentum real." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fes servir el tauler per triar deliberadament, el panell per protegir el flux i la columna Fet per mantenir l'impuls real."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutze das Board, um bewusst zu wählen, das Dashboard, um den Flow zu schützen, und die Erledigt-Spalte, damit Schwung sichtbar bleibt."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa el tablero para elegir con intención, el panel para proteger el flujo y la columna Terminado para mantener el impulso real."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilisez le tableau pour choisir délibérément, le tableau de bord pour protéger le flux et la colonne Terminé pour garder un élan réel."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सोच-समझकर चुनने के लिए बोर्ड, फ़्लो बचाने के लिए डैशबोर्ड, और गति को वास्तविक रखने के लिए पूरा कॉलम इस्तेमाल करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa il tabellone per scegliere deliberatamente, la dashboard per proteggere il flusso e la colonna Completato per mantenere reale lo slancio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ボードで意図的に選び、ダッシュボードで流れを守り、完了列で勢いを実感しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "보드로 신중하게 선택하고, 대시보드로 흐름을 보호하며, 완료 열로 실제 추진력을 유지하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gebruik het bord om bewust te kiezen, het dashboard om flow te beschermen en de Klaar-kolom om momentum echt te houden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Używaj tablicy, aby wybierać świadomie, pulpitu, aby chronić przepływ, i kolumny Ukończone, aby utrzymać realne momentum."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use o quadro para escolher com intenção, o painel para proteger o fluxo e a coluna Concluído para manter o impulso real."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用看板有意识地选择，用仪表盘保护流程，用已完成列让动能保持真实。"
          }
        }
      }
    },
