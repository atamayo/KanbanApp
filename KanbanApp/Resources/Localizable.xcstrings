    "Apple Intelligence is unavailable, so paste text here and add it to the task manually.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence no está disponible, así que pega el texto aquí y añádelo a la tarea manualmente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ist nicht verfügbar. Füge den Text hier ein und ergänze ihn manuell zur Aufgabe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 不可用。请在这里粘贴文本，然后手动添加到任务中。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence を利用できません。ここにテキストを貼り付け、手動でタスクに追加してください。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence उपलब्ध नहीं है, इसलिए टेक्स्ट यहाँ पेस्ट करें और उसे कार्य में मैन्युअली जोड़ें।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Apple Intelligence está indisponível. Cole o texto aqui e adicione-o à tarefa manualmente."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence를 사용할 수 없으므로 여기에 텍스트를 붙여 넣고 작업에 직접 추가하세요."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence est indisponible. Collez donc du texte ici et ajoutez-le manuellement à la tâche."
          }
        }
      }
    },
