    "NSCameraUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use the camera for Live Text scanning.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the camera to scan text and turn it into a task draft."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la cámara para escanear texto y convertirlo en un borrador de tarea."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende die Kamera, um Text zu scannen und daraus einen Aufgabenentwurf zu machen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用相机扫描文本，并将其转换为任务草稿。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラを使ってテキストをスキャンし、タスクの下書きに変換します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैमरे का उपयोग टेक्स्ट स्कैन करने और उसे कार्य ड्राफ़्ट में बदलने के लिए करें।"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use the microphone for voice capture.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the microphone to dictate a task and turn it into a task draft."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el micrófono para dictar una tarea y convertirla en un borrador de tarea."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende das Mikrofon, um eine Aufgabe zu diktieren und daraus einen Aufgabenentwurf zu machen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用麦克风听写任务，并将其转换为任务草稿。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクを使ってタスクを音声入力し、タスクの下書きに変換します。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "माइक्रोफ़ोन का उपयोग कार्य बोलकर लिखने और उसे कार्य ड्राफ़्ट में बदलने के लिए करें।"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "comment": "Privacy purpose string shown when the app asks to use speech recognition for voice capture.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use speech recognition to transcribe dictated tasks."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el reconocimiento de voz para transcribir tareas dictadas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende die Spracherkennung, um diktierte Aufgaben zu transkribieren."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用语音识别来转写听写的任务。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声認識を使って、音声入力したタスクを文字起こしします。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बोले गए कार्यों को टेक्स्ट में बदलने के लिए speech recognition का उपयोग करें।"
          }
        }
      }
    }
  },
  "version": "1.0"
}
