    "Reduce active work before starting anything new. This will protect focus and completion speed." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Redueix la feina activa abans de començar res nou. Això protegirà el focus i la velocitat de finalització."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reduziere aktive Arbeit, bevor du etwas Neues startest. Das schützt Fokus und Abschlussgeschwindigkeit."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reduce el trabajo activo antes de empezar nada nuevo. Esto protegerá el foco y la velocidad de finalización."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Réduisez le travail actif avant de commencer quoi que ce soit de nouveau. Cela protégera la concentration et la vitesse d’achèvement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कुछ नया शुरू करने से पहले सक्रिय काम घटाएँ। इससे फोकस और पूरा करने की गति बचती है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riduci il lavoro attivo prima di iniziare qualcosa di nuovo. Questo proteggerà concentrazione e velocità di completamento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいことを始める前に、アクティブな作業を減らしましょう。集中と完了スピードを守れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새로 시작하기 전에 활성 작업을 줄이세요. 그러면 집중과 완료 속도를 보호할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verminder actief werk voordat je iets nieuws start. Dit beschermt focus en voltooiingssnelheid."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogranicz aktywną pracę, zanim zaczniesz coś nowego. To ochroni skupienie i tempo kończenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reduza o trabalho ativo antes de começar algo novo. Isso protege o foco e a velocidade de conclusão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开始新工作前，先减少活跃工作。这样能保护专注和完成速度。"
          }
        }
      }
    },
