    "Limit work in progress to reduce context switching.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Begrenze Arbeit in Arbeit, um Kontextwechsel zu reduzieren."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Limita el trabajo en curso para reducir los cambios de contexto."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limitez le travail en cours pour réduire les changements de contexte."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "context switching कम करने के लिए चल रहा काम सीमित करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Limita il lavoro in corso per ridurre il cambio di contesto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中の作業を制限して、コンテキストスイッチを減らします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중 작업을 제한해 컨텍스트 전환을 줄이세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beperk werk in uitvoering om contextwissels te verminderen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limite o trabalho em andamento para reduzir troca de contexto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "限制进行中的工作，减少上下文切换。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogranicz pracę w toku, aby zmniejszyć przełączanie kontekstu."
          }
        }
      }
    },
