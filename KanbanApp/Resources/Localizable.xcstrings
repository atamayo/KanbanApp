    "Archived Done tasks leave the active board but still count toward completion history." : {
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les tasques fetes arxivades surten del tauler actiu però continuen comptant a l'historial de finalitzacions."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivierte erledigte Aufgaben verlassen das aktive Board, zählen aber weiterhin zur Abschluss-Historie."
          }
        },
        "es-ES" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las tareas terminadas archivadas salen del tablero activo, pero siguen contando en el historial de finalización."
          }
        },
        "fr-FR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les tâches terminées archivées quittent le tableau actif, mais comptent toujours dans l’historique d’achèvement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आर्काइव किए गए पूरे कार्य सक्रिय बोर्ड से हट जाते हैं, लेकिन पूरा होने के इतिहास में गिने जाते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le attività Completate archiviate escono dal tabellone attivo, ma contano comunque nella cronologia dei completamenti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アーカイブした完了タスクはアクティブなボードから外れますが、完了履歴には残ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "보관된 완료 작업은 활성 보드에서는 사라지지만 완료 기록에는 계속 포함됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gearchiveerde Klaar-taken verlaten het actieve bord, maar tellen nog steeds mee in de voltooiingsgeschiedenis."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zarchiwizowane ukończone zadania znikają z aktywnej tablicy, ale nadal liczą się w historii ukończeń."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tarefas concluídas arquivadas saem do quadro ativo, mas ainda contam no histórico de conclusão."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "归档的已完成任务会离开活跃看板，但仍会计入完成历史。"
          }
        }
      }
