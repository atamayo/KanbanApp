    "Every completed task frees attention and opens space for the next pull.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede erledigte Aufgabe macht Aufmerksamkeit frei und schafft Platz für die nächste Aufgabe."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada tarea completada libera atención y abre espacio para traer la siguiente."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque tâche terminée libère de l’attention et ouvre de la place pour la prochaine prise."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर पूरा कार्य ध्यान खाली करता है और अगला काम लेने की जगह बनाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni attività completata libera attenzione e apre spazio per il prossimo pull."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクを 1 つ完了するたびに注意力が空き、次の作業を引き込む余地が生まれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "완료된 작업 하나하나가 주의를 비우고 다음 작업을 가져올 공간을 만듭니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke voltooide taak maakt aandacht vrij en opent ruimte voor de volgende pull."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada tarefa concluída libera atenção e abre espaço para puxar a próxima."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每完成一个任务，都会释放注意力，并为下一次拉入工作腾出空间。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każde ukończone zadanie uwalnia uwagę i robi miejsce na kolejne."
