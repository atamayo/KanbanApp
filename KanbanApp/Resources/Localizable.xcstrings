        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최대 용량입니다! “%@”을(를) 끝내면 공간이 생깁니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je zit op piekcapaciteit! “%@” afronden maakt ruimte vrij."
          }
        },
        "pt-BR": {
