    "Move a task into In Progress only when capacity opens up. Let completion create space for the next commitment.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve una tarea a En curso solo cuando se abra capacidad. Deja que terminar cree espacio para el siguiente compromiso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschiebe eine Aufgabe nur dann nach In Arbeit, wenn Kapazität frei wird. Lass Abschlüsse Platz für das nächste Commitment schaffen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当容量释放出来时，才把任务移动到“进行中”。让完成为下一个承诺腾出空间。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "余裕ができたときだけタスクを「進行中」に移しましょう。完了によって次の約束のための空間を作ります。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य को “प्रगति में” तभी ले जाएँ जब जगह बने। पूरा होना अगले commitment के लिए जगह बनाता है।"
          }
        }
      }
    },
