    "Describe one task naturally. You can edit the generated task before saving.": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Describe una tarea de forma natural. Puedes editar la tarea generada antes de guardarla."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beschreibe eine Aufgabe ganz natürlich. Du kannst die generierte Aufgabe vor dem Speichern bearbeiten."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用自然语言描述一个任务。保存前你可以编辑生成的任务。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タスクを自然な言葉で説明してください。生成されたタスクは保存前に編集できます。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक कार्य को सहज भाषा में लिखें। सेव करने से पहले आप बनाए गए कार्य को संपादित कर सकते हैं।"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Descreva uma tarefa naturalmente. Você pode editar a tarefa gerada antes de salvar."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업 하나를 자연스럽게 설명하세요. 저장하기 전에 생성된 작업을 수정할 수 있습니다."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Décrivez naturellement une tâche. Vous pouvez modifier la tâche générée avant de l’enregistrer."
          }
        }
      }
    },
