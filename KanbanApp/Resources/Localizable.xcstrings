    "Move a task into In Progress only when capacity opens up. Let completion create space for the next commitment.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verschiebe eine Aufgabe nur dann nach In Arbeit, wenn Kapazität frei wird. Lass Abschlüsse Platz für das nächste Commitment schaffen."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve una tarea a En curso solo cuando se abra capacidad. Deja que terminar cree espacio para el siguiente compromiso."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez une tâche vers En cours uniquement quand de la capacité se libère. Laissez l’achèvement créer de la place pour le prochain engagement."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कार्य को “प्रगति में” तभी ले जाएँ जब जगह बने। पूरा होना अगले commitment के लिए जगह बनाता है।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sposta un’attività in In corso solo quando si libera capacità. Lascia che il completamento crei spazio per il prossimo impegno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "余裕ができたときだけタスクを「進行中」に移しましょう。完了によって次の約束のための空間を作ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여유가 생겼을 때만 작업을 진행 중으로 옮기세요. 완료가 다음 약속을 위한 공간을 만들게 하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verplaats een taak alleen naar In uitvoering wanneer er capaciteit vrijkomt. Laat voltooiing ruimte maken voor de volgende commitment."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova uma tarefa para Em andamento só quando houver capacidade. Deixe a conclusão criar espaço para o próximo compromisso."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当容量释放出来时，才把任务移动到“进行中”。让完成为下一个承诺腾出空间。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przenieś zadanie do W toku dopiero wtedy, gdy pojawi się miejsce. Niech ukończenie tworzy przestrzeń na kolejne zobowiązanie."
          }
        }
      }
    },
