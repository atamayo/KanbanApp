            "state": "translated",
            "value": "完了とはどんな状態ですか？"
          }
        }
      }
    },
    "What needs to be done?": {
      "localizations": {
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Qué hay que hacer?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was muss erledigt werden?"
          }
