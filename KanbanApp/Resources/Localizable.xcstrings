    "Send one daily reminder when In Progress tasks are aging or stalled.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sende täglich eine Erinnerung, wenn In-Arbeit-Aufgaben altern oder feststecken."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Envía un recordatorio diario cuando las tareas En curso estén envejeciendo o estancadas."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envoyer un rappel quotidien quand les tâches En cours vieillissent ou sont bloquées."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब प्रगति में कार्य लंबे खिंचें या रुकें, तो रोज़ एक reminder भेजें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invia un promemoria giornaliero quando le attività In corso stanno invecchiando o sono in stallo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中のタスクが長引いたり停滞したりしているとき、1 日 1 回リマインダーを送信します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "진행 중 작업이 오래되거나 지연되면 하루에 한 번 알림을 보냅니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuur één dagelijkse herinnering wanneer taken In uitvoering verouderen of vastlopen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Envie um lembrete diário quando tarefas Em andamento estiverem envelhecendo ou paradas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当进行中的任务变久或停滞时，每天发送一次提醒。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyślij jedno dzienne przypomnienie, gdy zadania W toku się starzeją lub zatrzymują."
          }
        }
      }
    },
